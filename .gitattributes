# Normalize text files in the repository.
* text=auto

# Keep source files with LF line endings.
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf

# Windows scripts should keep CRLF line endings.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
